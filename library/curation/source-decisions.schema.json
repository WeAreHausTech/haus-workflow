{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["decisions"],
  "properties": {
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "ideasAccepted", "ideasRejected"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "ideasAccepted": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "idea",
                "target",
                "reason",
                "copied",
                "maintenanceRisk",
                "licenseAttributionConcern",
                "productFit"
              ],
              "properties": {
                "idea": { "type": "string", "minLength": 1 },
                "target": { "type": "string", "minLength": 1 },
                "reason": { "type": "string", "minLength": 1 },
                "copied": { "const": false },
                "maintenanceRisk": {
                  "type": "string",
                  "enum": ["low", "medium", "high"]
                },
                "licenseAttributionConcern": {
                  "type": "string",
                  "enum": ["none", "low", "medium", "high"]
                },
                "productFit": {
                  "type": "string",
                  "enum": ["strong", "medium", "weak", "reject"]
                }
              }
            }
          },
          "ideasRejected": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["idea", "reason"],
              "properties": {
                "idea": { "type": "string", "minLength": 1 },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
