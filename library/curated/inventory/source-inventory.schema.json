{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "sources"],
  "properties": {
    "version": { "type": "string", "description": "Schema version, e.g. \"0.1.0\"." },
    "generatedAt": { "type": "string", "description": "ISO 8601 date when this inventory was last updated." },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "sourceUrl", "license", "licenseConfidence", "auditedAt", "items"],
        "properties": {
          "sourceId": { "type": "string", "description": "Must match an id in library/catalog/sources.yaml." },
          "sourceUrl": { "type": "string", "description": "Canonical URL of the source." },
          "license": { "type": "string", "description": "SPDX license identifier or \"unknown\"." },
          "licenseConfidence": {
            "type": "string",
            "enum": ["high", "medium", "low", "unknown"]
          },
          "auditedAt": { "type": "string", "description": "ISO 8601 date of the audit." },
          "auditNotes": { "type": "string" },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "name", "kind", "pathOrUrl", "summary", "reviewStatus"],
              "properties": {
                "id": { "type": "string", "description": "Namespaced identifier, e.g. \"anthropic.pdf-tool\"." },
                "name": { "type": "string" },
                "kind": {
                  "type": "string",
                  "enum": ["skill", "agent", "hook", "command", "mcp-config", "workflow", "reference", "rule"]
                },
                "pathOrUrl": { "type": "string", "description": "Relative path within source repo or direct URL." },
                "detectedStacks": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "summary": { "type": "string", "minLength": 1 },
                "reviewStatus": {
                  "type": "string",
                  "enum": ["candidate", "approved", "rejected", "needs-review", "deprecated"]
                },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
