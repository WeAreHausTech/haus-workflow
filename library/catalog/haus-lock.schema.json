{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "type", "source", "version", "hash", "installMode", "paths"],
    "properties": {
      "id": { "type": "string" },
      "type": { "type": "string" },
      "source": { "type": "string" },
      "version": { "type": "string" },
      "hash": { "type": "string" },
      "installMode": { "type": "string" },
      "paths": { "type": "array", "items": { "type": "string" } }
    }
  }
}
