{
  "name": "@haus/ai",
  "version": "0.1.0",
  "description": "Haus AI workflow package for Claude Code.",
  "type": "module",
  "bin": {
    "haus": "./dist/cli.js"
  },
  "files": [
    "dist",
    "library",
    "plugin",
    "docs/user-guide.md",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean --out-dir dist",
    "dev": "tsx src/cli.ts",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src scripts",
    "format:check": "prettier --check src scripts",
    "format:write": "prettier --write src scripts",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit --project tsconfig.scripts.json",
    "catalog:audit": "tsx scripts/verify-no-unsupported-tech.ts",
    "sources:audit": "tsx scripts/audit-sources.ts",
    "sources:decisions": "tsx scripts/validate-source-decisions.ts",
    "library:audit": "tsx scripts/library-audit.ts",
    "curated:audit": "tsx scripts/audit-curated.ts",
    "pack:local": "yarn pack",
    "publish:dry": "yarn npm publish --dry-run",
    "publish:private": "yarn npm publish --access restricted",
    "prepack": "yarn build && yarn catalog:audit && yarn sources:audit && yarn sources:decisions && yarn library:audit && yarn curated:audit",
    "verify": "yarn typecheck && yarn typecheck:scripts && yarn lint && yarn test && yarn prepack",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "diff": "^7.0.0",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.2.0",
    "ignore": "^6.0.2",
    "picomatch": "^4.0.2",
    "semver": "^7.7.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "packageManager": "yarn@4.5.3",
  "lint-staged": {
    "**/*.ts": [
      "eslint",
      "prettier --write"
    ]
  }
}
