{
  "name": "@haus-tech/haus-workflow",
  "version": "0.27.1",
  "description": "Haus AI workflow CLI for Claude Code.",
  "type": "module",
  "bin": {
    "haus": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WeAreHausTech/haus-workflow.git"
  },
  "homepage": "https://github.com/WeAreHausTech/haus-workflow",
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "library/global",
    "library/catalog",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean --out-dir dist --external @inquirer/checkbox",
    "dev": "tsx src/cli.ts",
    "test": "node scripts/run-tests.mjs tests/**/*.test.js",
    "test:fast": "node scripts/test-fast.mjs",
    "test:coverage": "c8 yarn test",
    "coverage:check": "c8 --check-coverage yarn test",
    "lint": "eslint src",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "pack:local": "yarn pack",
    "release": "GITHUB_TOKEN=$(gh auth token) release-it",
    "release:dry": "GITHUB_TOKEN=$(gh auth token) release-it --dry-run",
    "prepack": "yarn build",
    "verify": "yarn typecheck && yarn lint && yarn build && yarn test",
    "verify:full": "yarn verify && yarn coverage:check",
    "postinstall": "node ./scripts/postinstall.mjs || true",
    "prepare": "lefthook install || true",
    "security:audit": "yarn npm audit -A -R --severity high --environment production"
  },
  "dependencies": {
    "@inquirer/checkbox": "5.1.5",
    "commander": "13.1.0",
    "diff": "8.0.4",
    "execa": "9.6.1",
    "fast-glob": "3.3.3",
    "fs-extra": "11.3.5",
    "semver": "7.8.0",
    "yaml": "2.8.4"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "11.0.0",
    "@types/fs-extra": "11.0.4",
    "@types/node": "22.19.17",
    "@types/semver": "7.7.1",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "c8": "11.0.0",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "lefthook": "1.13.6",
    "prettier": "3.8.3",
    "release-it": "20.0.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.15.0",
  "dependenciesMeta": {
    "lefthook": {
      "built": true
    }
  }
}
